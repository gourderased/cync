#!/usr/bin/env bash
# uninstall — entry point. Just delegates to lib/uninstall.sh.
# Usage: bash ~/.cync/uninstall
set -euo pipefail

CYNC_DIR="${CYNC_DIR:-$HOME/.cync}"

if [ ! -x "$CYNC_DIR/lib/uninstall.sh" ]; then
  echo "xx  $CYNC_DIR/lib/uninstall.sh not found — is cync installed?" >&2
  exit 1
fi

exec "$CYNC_DIR/lib/uninstall.sh" "$@"
